# Скопируйте файл в .env и заполните реальные SMTP-данные почты.
# Для Яндекс 360 / Mail.ru / Gmail обычно нужен пароль приложения, а не пароль от аккаунта.

PORT=3000

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=site@example.ru
SMTP_PASS=app-password-here

MAIL_FROM="Груз-Сервис сайт <site@example.ru>"
LEAD_TO=manager@example.ru
